# ============================================
# Production environment variables
# Copy to /opt/app/.env on ECS and fill real values
# ============================================

# ---- GitHub Container Registry ----
GITHUB_REPO_OWNER=your-github-username

# ---- MySQL ----
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/db2504?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-db-password

# ---- JWT ----
JWT_SECRET=your-base64-encoded-secret-key
JWT_EXPIRATION=86400000

# ---- Logging ----
LOG_LEVEL=info
